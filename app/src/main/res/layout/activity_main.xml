<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Section Hello JNI -->
        <Button
            android:id="@+id/btnHello"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Hello from JNI"
            android:backgroundTint="#4CAF50" />

        <!-- Section Factoriel -->
        <EditText
            android:id="@+id/etFactorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Entrez un nombre (ex: 10)"
            android:inputType="number"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnFact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Calculer factoriel" />

        <!-- Section Inversion de chaîne -->
        <EditText
            android:id="@+id/etReverse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Texte à inverser (ex: JNI is cool)"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnReverse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Inverser la chaîne" />

        <!-- Section Somme tableau -->
        <EditText
            android:id="@+id/etArray"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombres séparés par virgules (ex: 10,20,30)"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnArray"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. Somme du tableau" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--- Résultats ---"
            android:textSize="16sp"
            android:paddingTop="24dp"
            android:background="#F5F5F5"
            android:minHeight="200dp"
            android:typeface="monospace" />

    </LinearLayout>
</ScrollView>